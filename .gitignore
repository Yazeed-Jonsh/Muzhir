**/.venv/

# Firebase / GCP — never commit private keys or local client configs
**/serviceAccountKey.json
**/*serviceAccount*.json
**/google-services.json
**/GoogleService-Info.plist

# FlutterFire-generated options (regenerate per machine / CI secret if needed)
mobile_app/lib/firebase_options.dart

# Project-local Firebase CLI file under app dir only (root firebase.json is tracked)
mobile_app/firebase.json

backend/assets/best.pt

# Backend: duplicate exports of mobile YOLO artifacts (canonical files live under
# mobile_app/assets/models/ and android/app/src/main/assets/). Keep
# backend/config/class_map.json — not ignored here.
backend/assets/muzhir_*.tflite
backend/assets/muzhir_ios_coreml.zip
backend/assets/muzhir_ios_coreml/

# Python bytecode (never commit)
**/__pycache__/
*.py[cod]
*.pyc
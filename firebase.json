{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "python312",
    "ignore": [
      ".git",
      ".git/**",
      "venv",
      "venv/**",
      ".venv",
      ".venv/**",
      "__pycache__",
      "**/__pycache__/**",
      "*.pyc",
      "*.pyo",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ]
  }
}
